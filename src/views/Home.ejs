<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List Users</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        /* Phần Header chứa tiêu đề và nút bấm */
        .box {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        h1 {
            font-size: 32px;
            margin: 0;
        }

        /* Style cho nút Create a new user */
        .btn-create {
            background-color: #f1c40f;
            /* Màu vàng */
            color: black;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            font-size: 14px;
        }

        .btn-create:hover {
            background-color: #d4ac0d;
        }

        /* Style cho Bảng dữ liệu */
        table {
            width: 100%;
            border-collapse: collapse;
            /* Để các đường kẻ dính liền nhau */
            margin-top: 10px;
        }

        th,
        td {
            border: 1px solid #ddd;
            padding: 12px;
            text-align: left;
        }

        th {
            background-color: #fff;
            font-weight: bold;
        }

        /* Style cho nút Delete */
        .btn-delete {
            background-color: #ff0000;
            /* Màu đỏ */
            color: white;
            padding: 8px 16px;
            text-decoration: none;
            border-radius: 5px;
            font-size: 14px;
            border: none;
            cursor: pointer;
        }

        .btn-delete:hover {
            background-color: #cc0000;
        }
    </style>
</head>

<body>

    <div class="box">
        <div>
            <h1>List Users:</h1>
        </div>
        <div>
            <a href="/Create" class="btn-create">Create a new user</a>
        </div>
    </div>

    <hr style="border: 0.5px solid #eee; margin-bottom: 20px;">

    <table>
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Email</th>
                <th>Address</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach( function (user) { %>
                <tr>
                        <td><%= user.id %></td>
                        <td><%=user.name %></td>
                        <td><%=user.email %></td>
                        <td><%= user.addrest %></td>
                        <td>
                            <button class="btn-delete">Delete</button>
                        </td>
                    </tr>
                <% }) %>      
        </tbody>
    </table>

</body>

</html>