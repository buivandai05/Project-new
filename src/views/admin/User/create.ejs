<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="Hỏi Dân IT - Dự án laptopshop" />
    <meta name="author" content="Hỏi Dân IT" />

    <title>Dashboard - Bui Van Dai</title>

    <link href="/admin/css/styles.css" rel="stylesheet" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script>
        $(document).ready(() => {
            const avatarFile = $("#avatarFile");
            avatarFile.change(function (e) {
                const imgURL = URL.createObjectURL(e.target.files[0]);
                $("#avatarPreview").attr("src", imgURL);
                $("#avatarPreview").css({ "display": "block" });
            });
        });
    </script>


    <style>
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        th,
        td {
            border: 1px solid #ddd;
            padding: 12px;
            text-align: left;
        }

        th {
            background-color: #fff;
            font-weight: bold;
        }

        .box {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .btn-create {
            background-color: #f1c40f;
            color: black;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            font-size: 14px;
        }

        .btn-delete {
            background-color: red;
            color: white;
            padding: 8px 16px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .btn-delete:hover {
            background-color: #cc0000;
        }

        .form-example {
            margin-bottom: 15px;
        }

        input {
            padding: 8px;
            width: 300px;
        }

        .container {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 40px;
        }

        .form-box {
            width: 400px;
        }
    </style>
</head>

<body class="sb-nav-fixed">

    <%- include('../Layout/header'); -%>

        <div id="layoutSidenav">

            <%- include('../Layout/navbar'); -%>

                <div id="layoutSidenav_content">

                    <main>
                        <div class="container-fluid px-4">

                            <h1 class="mt-4">Manage Users</h1>

                            <ol class="breadcrumb mb-4">
                                <li class="breadcrumb-item">
                                    <a href="/admin">Dashboard</a>
                                </li>
                                <li class="breadcrumb-item">
                                    <a href="/admin/User">user</a>
                                </li>
                            </ol>

                            <div class="box">
                                <h5>List Users:</h5>

                                <a href="/Create" class="btn-create">
                                    Create a new user
                                </a>
                            </div>

                            <hr style="border: 0.5px solid #eee; margin-bottom: 20px;">

                            <div class="container">
                                <div class="form-box">
                                    <form action="/admin/hanld-create-user" method="post" enctype="multipart/form-data">

                                        <div class="form-example">
                                            <label>Fullname:</label><br>
                                            <input  name="fullname" type="text" required />
                                        </div>

                                        <div class="form-example">
                                            <label>Email:</label><br>
                                            <input name="email" type="email" required />
                                        </div>
                                        <div class="row">
                                            <div class=" col-6">
                                                <label class="form-label">Phone</label>
                                                <input type="text" class="form-control" name="phone">
                                            </div>
                                            <div class="mb-3 col-6">
                                                <label class="form-label">Role</label>
                                                <select name="role" class="form-select">
                                                    <% roles.forEach((role,index)=> { %>
                                                        <option value="<%-role.id %>">
                                                            <%- role.username %>
                                                        </option>
                                                        <%})%>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label for="formFile" class="form-label">Avarta</label>
                                            <input name="avatar" class="form-control" type="file" id="avatarFile"
                                                accept=".png, .jpg, .jpeg">
                                        </div>
                                        <img style="max-height: 250px; display: none;" alt="avatar preview"
                                            id="avatarPreview" />

                                        <div class="form-example">
                                            <label>Address:</label><br>
                                            <input type="text" name="address" placeholder="Nhập địa chỉ">
                                        </div>

                                        <div class="form-example">
                                            <input type="submit" value="Subscribe!" />
                                        </div>

                                    </form>
                                </div>
                            </div>

                        </div>
                    </main>

                    <footer class="py-4 bg-light mt-auto">
                        <%- include('../Layout/footer'); -%>
                    </footer>

                </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>

        <script src="/admin/js/scripts.js"></script>

</body>

</html>