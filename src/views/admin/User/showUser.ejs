<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="Hỏi Dân IT - Dự án laptopshop" />
    <meta name="author" content="Hỏi Dân IT" />
    <title>Dashboard - Bui Van Dai</title>
    <link href="/admin/css/styles.css" rel="stylesheet" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
</head>
<style>
    table {
        width: 100%;
        border-collapse: collapse;
        /* Để các đường kẻ dính liền nhau */
        margin-top: 10px;
    }

    th,
    td {
        border: 1px solid #ddd;
        padding: 12px;
        text-align: left;
    }
    .box {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
         .btn-create {
            background-color: #f1c40f;
            /* Màu vàng */
            color: black;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            font-size: 14px;
        }


    th {
        background-color: #fff;
        font-weight: bold;
    }

    /* Style cho nút Delete */
    .btn-delete {
        background-color: #ff0000;
        /* Màu đỏ */
        color: white;
        padding: 8px 16px;
        text-decoration: none;
        border-radius: 5px;
        font-size: 14px;
        border: none;
        cursor: pointer;
    }

    .btn-delete:hover {
        background-color: #cc0000;
    }
</style>

<body class="sb-nav-fixed">
    <%- include('../Layout/header'); -%>

        <div id="layoutSidenav">
            <%- include('../Layout/navbar'); -%>
                <div id="layoutSidenav_content">
                    <main>
                        <div class="container-fluid px-4">
                            <h1 class="mt-4">Manage Users</h1>
                            <ol class="breadcrumb mb-4">
                                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                                <li class="breadcrumb-item active">Users</li>
                            </ol>

                            <div class="box">
                                <div>
                                    <h5>List Users:</h5>
                                </div>
                                <div>
                                    <a href="/admin/create" class="btn-create">Create a new user</a>
                                </div>
                            </div>

                            <hr style="border: 0.5px solid #eee; margin-bottom: 20px;">

                            <div>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Id</th>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Address</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% users.forEach( function (user) { %>
                                            <tr>
                                                <td>
                                                    <%=user.id %>
                                                </td>
                                                <td>
                                                    <%=user.fullName %>
                                                </td>
                                                <td>
                                                    <%=user.username %>
                                                </td>
                                                <td>
                                                    <%=user.address %>
                                                </td>
                                                <td>
                                                    <div style="display: flex; gap: 10px;">
                                                        <form action="/admin/view-user/<%= user.id %>" method="get">
                                                            <button type="submit" class="btn-warning">View <%= user.id
                                                                    %></button>
                                                        </form>
                                                        <form action="/admin/delete-user/<%= user.id %>" method="post">
                                                            <button type="submit" class="btn-delete">Delete <%= user.id
                                                                    %></button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>

                            </div>
                        </div>

                    </main>
                    <footer class="py-4 bg-light mt-auto">
                        <%- include('../Layout/footer'); -%>
                    </footer>
                </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>
        <script src="/admin/js/scripts.js"></script>

</body>

</html>